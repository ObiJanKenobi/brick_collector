{
  "manifest_version": 3,
  "name": "yourwobb → Rebrickable CSV",
  "version": "1.0.0",
  "description": "Scan a yourwobb GoBricks shopping cart and export a Rebrickable-compatible parts CSV (Part,Color,Quantity).",
  "permissions": ["scripting", "activeTab", "downloads"],
  "host_permissions": ["*://*.yourwobb.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "yourwobb → Rebrickable CSV",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
